# ── Django core ────────────────────────────────────────────────────────────
# Generate a strong key with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=your-secret-key-here

# Set to False in production
DEBUG=False

# Comma-separated list of allowed hostnames (no spaces)
ALLOWED_HOSTS=yourdomain.render.com,localhost,127.0.0.1

# ── Database ───────────────────────────────────────────────────────────────
# Leave unset to use the local SQLite file (db.sqlite3)
# Set to a PostgreSQL URL for production
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the mobile/web frontend.
# Include any Expo dev/preview origins (e.g. https://<slug>--<hash>.expo.app).
CORS_ALLOWED_ORIGINS=https://yourapp.com,http://localhost:8081,http://127.0.0.1:8081

# Comma-separated list of trusted origins for CSRF (must match CORS origins
# that use session auth). Typically the https frontend origins.
CSRF_TRUSTED_ORIGINS=https://yourapp.com

# ── AI / OpenAI or Sarvam ──────────────────────────────────────────────────
# Set AI_PROVIDER to 'sarvam' to use Sarvam AI, or 'openai' for OpenAI / compatible.
AI_PROVIDER=sarvam

# Sarvam AI subscription key — used when AI_PROVIDER=sarvam
# Get your key at https://dashboard.sarvam.ai
AI_API_KEY=your-sarvam-subscription-key-here
# NOTE: Sarvam's chat endpoint is /v1/chat/completions — the /v1 is required.
AI_BASE_URL=https://api.sarvam.ai/v1
AI_MODEL=sarvam-30b

# OpenAI (or compatible) — used when AI_PROVIDER=openai
# AI_API_KEY=your-openai-api-key-here
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# ── Email (optional — only needed for password-reset emails) ───────────────
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=you@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=PathFindr <noreply@yourdomain.com>
